<header class="bg-white border-b border-gray-200 fixed top-0 left-0 right-0 z-50">
    <nav class="container mx-auto flex justify-between items-center px-4 py-3">

        <!-- Logo -->
        <a href="/" class="text-2xl font-bold text-pink-600 tracking-tight">
            airbnb
        </a>

        <!-- Desktop Menu -->
        <ul class="hidden md:flex space-x-1">
            <li>
                <a href="/homes"
                    class="py-2 px-4 rounded-md transition duration-200 
             <%= currentPage === 'homes' ? 'bg-pink-100 text-pink-600 font-semibold' : 'text-gray-700 hover:bg-gray-100' %>">
                    Homes
                </a>
            </li>
            <li>
                <a href="/host/add-home"
                    class="py-2 px-4 rounded-md transition duration-200 
             <%= currentPage === 'addHome' ? 'bg-pink-100 text-pink-600 font-semibold' : 'text-gray-700 hover:bg-gray-100' %>">
                    Host-Home
                </a>
            </li>
            <li>
                <% user=false %>
                    <% if (!user) { %>
                        <a href="/login"
                            class="py-2 px-4 rounded-md bg-pink-600 text-white hover:bg-pink-700 ml-2 transition">Login</a>
                        <a href="/signup"
                            class="py-2 px-4 rounded-md bg-white text-pink-600 border border-pink-600 hover:bg-pink-50 ml-2 transition">Signup</a>
                        <% } else { %>
                            <!-- User dropdown, avatar, or just a 'Logout' button here -->
                            <span class="ml-4 font-semibold text-pink-600">Hi, <%= user.name %></span>
                            <a href="/logout" class="py-2 px-4 rounded-md hover:bg-gray-100 ml-2 transition">Logout</a>
                            <% } %>
            </li>

        </ul>

        <!-- Mobile Menu Button -->
        <button class="md:hidden text-gray-700 focus:outline-none" id="menu-toggle">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
        </button>
    </nav>

    <!-- Mobile Menu -->
    <div class="md:hidden hidden flex-col space-y-1 bg-white border-t border-gray-200 px-4 pb-4" id="mobile-menu">
        <a href="/homes"
            class="block p-2 rounded-md <%= currentPage === 'homes' ? 'bg-pink-100 text-pink-600 font-semibold' : 'text-gray-700 hover:bg-gray-100' %>">Homes</a>
        <a href="/host/add-home"
            class="block p-2 rounded-md <%= currentPage === 'addHome' ? 'bg-pink-100 text-pink-600 font-semibold' : 'text-gray-700 hover:bg-gray-100' %>">Add
            Host-Home</a>
        <a href="/host/home-list"
            class="block p-2 rounded-md <%= currentPage === 'host-homes' ? 'bg-pink-100 text-pink-600 font-semibold' : 'text-gray-700 hover:bg-gray-100' %>">
            <% user=false %>
                <% if (!user) { %>
                    <a href="/login"
                        class="py-2 px-4 rounded-md bg-pink-600 text-white hover:bg-pink-700 ml-2 transition">Login</a>
                    <a href="/signup"
                        class="py-2 px-4 rounded-md bg-white text-pink-600 border border-pink-600 hover:bg-pink-50 ml-2 transition">Signup</a>
                <% } else { %>
                        <!-- User dropdown, avatar, or just a 'Logout' button here -->
                        <span class="ml-4 font-semibold text-pink-600">Hi, <%= user.name %></span>
                        <a href="/logout" class="py-2 px-4 rounded-md hover:bg-gray-100 ml-2 transition">Logout</a>
                <% } %>
        </a>
    </div>

    <script>
        document.getElementById('menu-toggle').addEventListener('click', function () {
            document.getElementById('mobile-menu').classList.toggle('hidden');
        });
    </script>
</header>