<%- include('../partials/head') %>
</head>
<body class="bg-gray-50 min-h-screen">
  <%- include('../partials/nav') %>
  <main class="flex flex-col justify-center items-center min-h-[75vh]">
    <form action="/signup" method="POST" class="w-full max-w-md bg-white p-8 rounded-xl shadow-lg mt-12">
      <h2 class="text-2xl font-bold text-center text-pink-600 mb-6">Sign Up</h2>
      <input type="text" name="name" placeholder="Name" required class="mb-4 w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-pink-500 transition"/>
      <input type="email" name="email" placeholder="Email" required class="mb-4 w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-pink-500 transition"/>
      <input type="password" name="password" placeholder="Password" required class="mb-4 w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-pink-500 transition"/>
      <button type="submit" class="w-full bg-pink-600 hover:bg-pink-700 text-white py-3 rounded-lg font-semibold transition">Signup</button>
      <p class="mt-4 text-sm text-gray-600 text-center">Already have an account? <a href="/login" class="text-pink-600 font-semibold">Login</a></p>
    </form>
  </main>
</body>
</html>
